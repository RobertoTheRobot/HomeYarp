<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <HeadOutlet @rendermode="InteractiveServer" />
    <title>HomeYarp</title>
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    @* BlazorMonaco's jsInterop.js sets `var require = { paths: { vs: ... } }` at module
       top, so Monaco's AMD loader (loader.js) picks up the paths automatically — no
       inline `var require` block needed. The whole stack MUST run before blazor.web.js,
       otherwise the circuit prerenders JsonEditor while `window.monaco` is still undefined,
       BlazorMonaco throws, and the circuit dies on first request (symptoms: inputs don't
       focus, typing doesn't show, cursor doesn't blink). See BlazorMonaco 3.4.0 README. *@
    <script src="_content/BlazorMonaco/jsInterop.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/editor/editor.main.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
