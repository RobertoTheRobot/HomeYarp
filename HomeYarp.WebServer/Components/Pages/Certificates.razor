@page "/certificates"
@using HomeYarp.Application.Acme
@inject ICertificateService Service
@inject IAcmeService Acme
@rendermode InteractiveServer

<PageTitle>Certificates · HomeYarp</PageTitle>

<div class="page-header">
    <h1>Certificates</h1>
    <div>
        <a class="btn" href="certificates/request">+ Request via Let's Encrypt</a>
        <a class="btn primary" href="certificates/upload">+ Upload PEM</a>
    </div>
</div>

@if (_error is not null)
{
    <p class="error">@_error</p>
}

@if (_certs is null)
{
    <p>Loading…</p>
}
else if (_certs.Count == 0)
{
    <p class="empty">No certificates yet. Upload one or request from Let's Encrypt to enable TLS offload.</p>
}
else
{
    <table class="data">
        <thead>
            <tr>
                <th>Name</th>
                <th>Subject</th>
                <th>SANs</th>
                <th>Source</th>
                <th>Expires</th>
                <th class="actions"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cert in _certs)
            {
                <tr>
                    <td>
                        <strong>@cert.Name</strong>
                        @if (!string.IsNullOrWhiteSpace(cert.FriendlyName))
                        {
                            <div class="muted">@cert.FriendlyName</div>
                        }
                    </td>
                    <td><code>@cert.Subject</code></td>
                    <td>
                        @foreach (var san in cert.SubjectAlternativeNames)
                        {
                            <div><code>@san</code></div>
                        }
                    </td>
                    <td>
                        @if (cert.Acme is not null)
                        {
                            <span class="badge">ACME</span>
                            @if (cert.Acme.RenewedAt is { } renewed)
                            {
                                <div class="muted">renewed @renewed.ToString("yyyy-MM-dd")</div>
                            }
                            else
                            {
                                <div class="muted">issued @cert.Acme.IssuedAt.ToString("yyyy-MM-dd")</div>
                            }
                        }
                        else
                        {
                            <span class="muted">manual</span>
                        }
                    </td>
                    <td>
                        @cert.NotAfter.ToString("yyyy-MM-dd")
                        @if (cert.NotAfter < DateTimeOffset.UtcNow)
                        {
                            <span class="muted"> (expired)</span>
                        }
                    </td>
                    <td class="actions">
                        @if (cert.Acme is not null)
                        {
                            <button class="btn"
                                    disabled="@(_busyId == cert.Id)"
                                    @onclick="() => RenewAsync(cert)">
                                @(_busyId == cert.Id ? "Renewing…" : "Renew now")
                            </button>
                        }
                        <button class="btn danger" @onclick="() => DeleteAsync(cert)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<HomeYarp.Domain.Certificate>? _certs;
    private string? _error;
    private Guid? _busyId;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _error = null;
        _certs = await Service.ListAsync();
    }

    private async Task DeleteAsync(HomeYarp.Domain.Certificate cert)
    {
        await Service.DeleteAsync(cert.Id);
        await Reload();
    }

    private async Task RenewAsync(HomeYarp.Domain.Certificate cert)
    {
        _busyId = cert.Id;
        _error = null;
        try
        {
            await Acme.RenewAsync(cert.Id);
            await Reload();
        }
        catch (Exception ex)
        {
            _error = $"Renewal failed: {ex.Message}";
        }
        finally
        {
            _busyId = null;
        }
    }
}
