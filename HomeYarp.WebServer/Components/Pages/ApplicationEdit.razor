@page "/applications/new"
@page "/applications/{Id:guid}"
@using System.Text.Json
@using HomeYarp.Application.Acme
@using Microsoft.Extensions.Options
@inject IApplicationService Service
@inject ICertificateService CertificateService
@inject IOptionsMonitor<AcmeOptions> AcmeOptions
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New application" : _model.Name) · HomeYarp</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">@(_isNew ? "New application" : $"Edit {_model.Name}")</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="applications">Back</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudAlert Severity="Severity.Warning">Application not found.</MudAlert>
}
else
{
    <MudToggleGroup T="ViewMode"
                    Value="_view"
                    ValueChanged="OnViewChanged"
                    Color="Color.Primary"
                    Outlined="true"
                    Class="mb-4">
        <MudToggleItem Value="@ViewMode.Simple">Simple</MudToggleItem>
        <MudToggleItem Value="@ViewMode.Advanced">Advanced (JSON)</MudToggleItem>
    </MudToggleGroup>

    <div class="@(_view == ViewMode.Advanced ? null : "d-none")">
        <MudPaper Outlined="true" Class="pa-4 mb-3">
            <MudText Typo="Typo.body2" Class="mb-3">
                Edit the application's JSON directly. Supports everything in the domain — including
                YARP transforms, active/passive health checks, and per-cluster HTTP request options
                that aren't exposed in the simple form.
            </MudText>
            <JsonEditor @bind-Value="_jsonBuffer" Height="600px" />

            @if (_view == ViewMode.Advanced && !string.IsNullOrEmpty(_jsonError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="() => _jsonError = null">
                    @_jsonError
                </MudAlert>
            }
            @if (_view == ViewMode.Advanced && !string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                    @_error
                </MudAlert>
            }
            @if (_view == ViewMode.Advanced && _steps.Count > 0)
            {
                <div class="mt-3">
                    <ProgressLog Steps="_steps" />
                </div>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       Disabled="_saving"
                       OnClick="SaveAdvancedAsync"
                       Class="mt-3">
                @(_saving ? "Saving…" : "Save")
            </MudButton>
        </MudPaper>
    </div>

    <div class="@(_view == ViewMode.Simple ? null : "d-none")">
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudPaper Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Identity</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_model.Name"
                                      Label="Name (slug)"
                                      Required="true"
                                      RequiredError="Name is required"
                                      Variant="Variant.Outlined" />
                        <MudTextField @bind-Value="_model.DisplayName"
                                      Label="Display name"
                                      Variant="Variant.Outlined" />
                        <MudTextField @bind-Value="_model.Description"
                                      Label="Description"
                                      Lines="2"
                                      Variant="Variant.Outlined" />
                        <MudSwitch T="bool" @bind-Value="_model.Enabled" Label="Enabled" Color="Color.Primary" />
                        <MudTextField @bind-Value="_model.AuthorizationPolicy"
                                      Label="Authorization policy (optional)"
                                      Variant="Variant.Outlined" />
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">Routes</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   OnClick="AddRoute">Add route</MudButton>
                    </MudStack>
                    @for (var i = 0; i < _model.Routes.Count; i++)
                    {
                        var route = _model.Routes[i];
                        var index = i;
                        <MudGrid Spacing="2" Class="mb-2">
                            <MudItem xs="12" md="5">
                                <MudTextField T="string"
                                              Value="@string.Join(", ", route.Hosts)"
                                              ValueChanged="@(v => UpdateHosts(index, v))"
                                              Label="Hosts (comma separated)"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="route.Path"
                                              Label="Path"
                                              Placeholder="/{**catch-all}"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="8" md="2">
                                <MudNumericField T="int?" @bind-Value="route.Order"
                                                 Label="Order"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="4" md="1" Class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="() => _model.Routes.RemoveAt(index)" />
                            </MudItem>
                        </MudGrid>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">TLS</MudText>
                    <MudStack Spacing="3">
                        <MudSelect T="TlsMode" @bind-Value="_model.Tls.Mode" Label="Mode" Variant="Variant.Outlined">
                            <MudSelectItem Value="@TlsMode.None">None (HTTP only)</MudSelectItem>
                            <MudSelectItem Value="@TlsMode.Offload">Offload (proxy terminates TLS)</MudSelectItem>
                            <MudSelectItem Value="@TlsMode.Passthrough">Passthrough (raw TCP tunnel)</MudSelectItem>
                        </MudSelect>

                        @if (_model.Tls.Mode == TlsMode.Offload)
                        {
                            <MudText Typo="Typo.subtitle2">Certificate source</MudText>
                            <MudRadioGroup T="TlsCertificateSource"
                                           Value="_model.Tls.Source"
                                           ValueChanged="SetSource">
                                <MudRadio T="TlsCertificateSource" Value="@TlsCertificateSource.Internal" Color="Color.Primary">
                                    Internal — HomeYarp generates a self-signed certificate for the route hostnames
                                </MudRadio>
                                <MudRadio T="TlsCertificateSource" Value="@TlsCertificateSource.External"
                                          Color="Color.Primary"
                                          Disabled="@(!_acmeReady)">
                                    External — HomeYarp requests a certificate from Let's Encrypt
                                    @if (!_acmeReady)
                                    {
                                        <MudText Typo="Typo.caption" Class="d-inline">
                                            (configure ACME under <MudLink Href="settings">Settings</MudLink> first)
                                        </MudText>
                                    }
                                </MudRadio>
                                <MudRadio T="TlsCertificateSource" Value="@TlsCertificateSource.Manual" Color="Color.Primary">
                                    Use existing certificate
                                </MudRadio>
                            </MudRadioGroup>

                            @if (_model.Tls.Source == TlsCertificateSource.Manual)
                            {
                                <MudSelect T="Guid?" @bind-Value="_model.Tls.CertificateId"
                                           Label="Certificate" Variant="Variant.Outlined"
                                           Clearable="true">
                                    @foreach (var cert in _certificates)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)cert.Id)">
                                            @cert.Name (@cert.NotAfter.ToString("yyyy-MM-dd"))
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                                @if (_certificates.Count == 0)
                                {
                                    <MudText Typo="Typo.caption">
                                        No certificates yet — <MudLink Href="certificates/upload">upload one</MudLink> first.
                                    </MudText>
                                }
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    Hostnames are taken from the routes above. Save the application to create or update the certificate.
                                    @if (_model.Tls.Source == TlsCertificateSource.External)
                                    {
                                        <span> Each hostname must publicly resolve to this server, and inbound port 80 must reach the HTTP listener.</span>
                                    }
                                </MudAlert>
                            }
                        }
                        else if (_model.Tls.Mode == TlsMode.Passthrough)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Passthrough forwards encrypted bytes to the first destination. The backend must terminate TLS itself. Reachable on the passthrough port (default :5444).
                            </MudAlert>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">Cluster</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   OnClick="AddDestination">Add destination</MudButton>
                    </MudStack>
                    <MudTextField @bind-Value="_model.Cluster.LoadBalancingPolicy"
                                  Label="Load balancing policy (optional)"
                                  Placeholder="RoundRobin"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Destinations</MudText>
                    @for (var i = 0; i < _model.Cluster.Destinations.Count; i++)
                    {
                        var dest = _model.Cluster.Destinations[i];
                        var index = i;
                        <MudGrid Spacing="2" Class="mb-2">
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="dest.Name"
                                              Label="Name"
                                              Required="true"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField @bind-Value="dest.Address"
                                              Label="Address"
                                              Placeholder="https://example.com"
                                              Required="true"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="10" md="3">
                                <MudTextField @bind-Value="dest.Host"
                                              Label="Host header (optional)"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="2" md="1" Class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="() => _model.Cluster.Destinations.RemoveAt(index)" />
                            </MudItem>
                        </MudGrid>
                    }
                </MudPaper>
            </MudItem>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                        @_error
                    </MudAlert>
                </MudItem>
            }

            @if (_view == ViewMode.Simple && _steps.Count > 0)
            {
                <MudItem xs="12">
                    <ProgressLog Steps="_steps" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="_saving"
                           OnClick="SaveAsync">
                    @(_saving ? "Saving…" : "Save")
                </MudButton>
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true,
        Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
    };

    private enum ViewMode { Simple, Advanced }

    private HomeYarp.Domain.Application _model = NewModel();
    private IReadOnlyList<HomeYarp.Domain.Certificate> _certificates = Array.Empty<HomeYarp.Domain.Certificate>();
    private bool _isNew = true;
    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private bool _acmeReady;
    private string? _error;
    private ViewMode _view = ViewMode.Simple;
    private string _jsonBuffer = "{}";
    private string? _jsonError;
    private readonly List<ProgressStep> _steps = new();
    private IProgress<string>? _progress;

    protected override void OnInitialized()
    {
        // Constructed on the Blazor circuit, so callbacks resume on the right context.
        _progress = new Progress<string>(message =>
        {
            _steps.Add(new ProgressStep(DateTimeOffset.Now, message));
            StateHasChanged();
        });
    }

    protected override async Task OnParametersSetAsync()
    {
        _isNew = !Id.HasValue;
        _loading = true;
        _notFound = false;
        _error = null;

        _certificates = await CertificateService.ListAsync();
        _acmeReady = AcmeOptionsValidator.IsConfigured(AcmeOptions.CurrentValue);

        if (_isNew)
        {
            _model = NewModel();
        }
        else
        {
            var existing = await Service.GetAsync(Id!.Value);
            if (existing is null)
            {
                _notFound = true;
            }
            else
            {
                _model = existing;
            }
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        _steps.Clear();
        try
        {
            if (_isNew)
            {
                await Service.CreateAsync(_model, progress: _progress);
            }
            else
            {
                await Service.UpdateAsync(Id!.Value, _model, progress: _progress);
            }
            Nav.NavigateTo("applications");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnViewChanged(ViewMode next)
    {
        if (next == _view) return;
        if (next == ViewMode.Advanced)
        {
            _jsonBuffer = JsonSerializer.Serialize(_model, JsonOptions);
            _jsonError = null;
            _error = null;
            _view = ViewMode.Advanced;
            return;
        }
        // Switching back to Simple: parse the JSON buffer first.
        if (!TryParseJsonBuffer(out var parsed, out var error))
        {
            _jsonError = $"Fix the JSON before switching to Simple: {error}";
            return;
        }
        _model = parsed!;
        _jsonError = null;
        _error = null;
        _view = ViewMode.Simple;
    }

    private async Task SaveAdvancedAsync()
    {
        _saving = true;
        _error = null;
        _jsonError = null;
        _steps.Clear();

        if (!TryParseJsonBuffer(out var parsed, out var parseError))
        {
            _jsonError = parseError;
            _saving = false;
            return;
        }

        try
        {
            // Preserve identity for an update — the form's URL says which app this is.
            if (_isNew)
            {
                var created = await Service.CreateAsync(parsed!, progress: _progress);
                _model = created;
                Nav.NavigateTo("applications");
            }
            else
            {
                var updated = await Service.UpdateAsync(Id!.Value, parsed!, progress: _progress);
                _model = updated;
                Nav.NavigateTo("applications");
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private bool TryParseJsonBuffer(out HomeYarp.Domain.Application? parsed, out string? error)
    {
        parsed = null;
        error = null;
        if (string.IsNullOrWhiteSpace(_jsonBuffer))
        {
            error = "JSON is empty.";
            return false;
        }
        try
        {
            parsed = JsonSerializer.Deserialize<HomeYarp.Domain.Application>(_jsonBuffer, JsonOptions);
            if (parsed is null)
            {
                error = "JSON deserialized to null.";
                return false;
            }
            return true;
        }
        catch (JsonException ex)
        {
            error = ex.Message;
            return false;
        }
    }

    private void SetSource(TlsCertificateSource source)
    {
        _model.Tls.Source = source;
        if (source != TlsCertificateSource.Manual)
        {
            // Auto-managed sources own CertificateId — clear the user's stale pick so the service can populate on save.
            _model.Tls.CertificateId = null;
        }
    }

    private void AddRoute() => _model.Routes.Add(new RouteDefinition { Hosts = new List<string>() });

    private void AddDestination() => _model.Cluster.Destinations.Add(new DestinationDefinition
    {
        Name = $"dest-{_model.Cluster.Destinations.Count + 1}",
        Address = "https://"
    });

    private void UpdateHosts(int index, string? raw)
    {
        var hosts = string.IsNullOrWhiteSpace(raw)
            ? new List<string>()
            : raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        _model.Routes[index].Hosts = hosts;
    }

    private static HomeYarp.Domain.Application NewModel() => new()
    {
        Name = string.Empty,
        Routes = new List<RouteDefinition> { new() { Hosts = new List<string>() } },
        Cluster = new ClusterDefinition
        {
            Destinations = new List<DestinationDefinition>
            {
                new() { Name = "primary", Address = "https://" }
            }
        }
    };
}
