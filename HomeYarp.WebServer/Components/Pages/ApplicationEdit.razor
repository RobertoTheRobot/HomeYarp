@page "/applications/new"
@page "/applications/{Id:guid}"
@using System.Text.Json
@using HomeYarp.Application.Acme
@using Microsoft.Extensions.Options
@inject IApplicationService Service
@inject ICertificateService CertificateService
@inject IOptionsMonitor<AcmeOptions> AcmeOptions
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New application" : _model.Name) · HomeYarp</PageTitle>

<div class="page-header">
    <h1>@(_isNew ? "New application" : $"Edit {_model.Name}")</h1>
    <a class="btn" href="applications">Back</a>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_notFound)
{
    <p class="empty">Application not found.</p>
}
else
{
    <div class="view-toggle">
        <button type="button"
                class="view-toggle-btn @(_view == ViewMode.Simple ? "active" : null)"
                @onclick="SwitchToSimple">Simple</button>
        <button type="button"
                class="view-toggle-btn @(_view == ViewMode.Advanced ? "active" : null)"
                @onclick="SwitchToAdvanced">Advanced (JSON)</button>
    </div>

    <div class="advanced-view view-pane @(_view == ViewMode.Advanced ? null : "hidden")">
        <p class="muted">
            Edit the application's JSON directly. Supports everything in the domain — including
            YARP transforms, active/passive health checks, and per-cluster HTTP request options
            that aren't exposed in the simple form.
        </p>
        <JsonEditor @bind-Value="_jsonBuffer" Height="600px" />
        @if (_view == ViewMode.Advanced && !string.IsNullOrEmpty(_jsonError))
        {
            <div class="error">@_jsonError</div>
        }
        @if (_view == ViewMode.Advanced && !string.IsNullOrEmpty(_error))
        {
            <div class="error">@_error</div>
        }
        <div class="form-actions">
            <button type="button" class="btn primary" disabled="@_saving" @onclick="SaveAdvancedAsync">
                @(_saving ? "Saving…" : "Save")
            </button>
        </div>
    </div>

    <div class="view-pane @(_view == ViewMode.Simple ? null : "hidden")">
    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="application-edit">
        <fieldset>
            <legend>Identity</legend>
            <label>
                Name (slug)
                <input class="input" @bind="_model.Name" required />
            </label>
            <label>
                Display name
                <input class="input" @bind="_model.DisplayName" />
            </label>
            <label>
                Description
                <textarea class="input" rows="2" @bind="_model.Description"></textarea>
            </label>
            <label class="checkbox">
                <input type="checkbox" @bind="_model.Enabled" />
                Enabled
            </label>
            <label>
                Authorization policy (optional)
                <input class="input" @bind="_model.AuthorizationPolicy" />
            </label>
        </fieldset>

        <fieldset>
            <legend>Routes</legend>
            @for (var i = 0; i < _model.Routes.Count; i++)
            {
                var route = _model.Routes[i];
                var index = i;
                <div class="row">
                    <label>
                        Hosts (comma separated)
                        <input class="input" value="@string.Join(", ", route.Hosts)"
                               @onchange="e => UpdateHosts(index, e.Value?.ToString())" />
                    </label>
                    <label>
                        Path
                        <input class="input" @bind="route.Path" placeholder="/{**catch-all}" />
                    </label>
                    <label>
                        Order
                        <input class="input narrow" type="number" @bind="route.Order" />
                    </label>
                    <button type="button" class="btn danger" @onclick="() => _model.Routes.RemoveAt(index)">Remove</button>
                </div>
            }
            <button type="button" class="btn" @onclick="AddRoute">+ Add route</button>
        </fieldset>

        <fieldset>
            <legend>TLS</legend>
            <label>
                Mode
                <select class="input" @bind="_model.Tls.Mode">
                    <option value="@TlsMode.None">None (HTTP only)</option>
                    <option value="@TlsMode.Offload">Offload (proxy terminates TLS)</option>
                    <option value="@TlsMode.Passthrough">Passthrough (raw TCP tunnel)</option>
                </select>
            </label>
            @if (_model.Tls.Mode == TlsMode.Offload)
            {
                <label>
                    Certificate source
                </label>
                <div class="radio-group">
                    <label class="checkbox">
                        <input type="radio" name="cert-source"
                               checked="@(_model.Tls.Source == TlsCertificateSource.Internal)"
                               @onchange="() => SetSource(TlsCertificateSource.Internal)" />
                        Internal &mdash; HomeYarp generates a self-signed certificate for the route hostnames
                    </label>
                    <label class="checkbox">
                        <input type="radio" name="cert-source"
                               checked="@(_model.Tls.Source == TlsCertificateSource.External)"
                               disabled="@(!_acmeReady)"
                               @onchange="() => SetSource(TlsCertificateSource.External)" />
                        External &mdash; HomeYarp requests a certificate from Let's Encrypt
                        @if (!_acmeReady)
                        {
                            <span class="muted"> (configure ACME under <a href="settings">Settings</a> first)</span>
                        }
                    </label>
                    <label class="checkbox">
                        <input type="radio" name="cert-source"
                               checked="@(_model.Tls.Source == TlsCertificateSource.Manual)"
                               @onchange="() => SetSource(TlsCertificateSource.Manual)" />
                        Use existing certificate
                    </label>
                </div>

                @if (_model.Tls.Source == TlsCertificateSource.Manual)
                {
                    <label>
                        Certificate
                        <select class="input" @bind="_model.Tls.CertificateId">
                            <option value="">-- select a certificate --</option>
                            @foreach (var cert in _certificates)
                            {
                                <option value="@cert.Id">@cert.Name (@cert.NotAfter.ToString("yyyy-MM-dd"))</option>
                            }
                        </select>
                    </label>
                    @if (_certificates.Count == 0)
                    {
                        <p class="muted">No certificates yet — <a href="certificates/upload">upload one</a> first.</p>
                    }
                }
                else
                {
                    <p class="muted">
                        Hostnames are taken from the routes above. Save the application to create or update the certificate.
                        @if (_model.Tls.Source == TlsCertificateSource.External)
                        {
                            <span> Each hostname must publicly resolve to this server, and inbound port 80 must reach the HTTP listener.</span>
                        }
                    </p>
                }
            }
            else if (_model.Tls.Mode == TlsMode.Passthrough)
            {
                <p class="muted">Passthrough forwards encrypted bytes to the first destination. The backend must terminate TLS itself. Reachable on the passthrough port (default :5444).</p>
            }
        </fieldset>

        <fieldset>
            <legend>Cluster</legend>
            <label>
                Load balancing policy (optional)
                <input class="input" @bind="_model.Cluster.LoadBalancingPolicy" placeholder="RoundRobin" />
            </label>
            <h3>Destinations</h3>
            @for (var i = 0; i < _model.Cluster.Destinations.Count; i++)
            {
                var dest = _model.Cluster.Destinations[i];
                var index = i;
                <div class="row">
                    <label>
                        Name
                        <input class="input" @bind="dest.Name" required />
                    </label>
                    <label>
                        Address
                        <input class="input wide" @bind="dest.Address" placeholder="https://example.com" required />
                    </label>
                    <label>
                        Host header (optional)
                        <input class="input" @bind="dest.Host" />
                    </label>
                    <button type="button" class="btn danger" @onclick="() => _model.Cluster.Destinations.RemoveAt(index)">Remove</button>
                </div>
            }
            <button type="button" class="btn" @onclick="AddDestination">+ Add destination</button>
        </fieldset>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="error">@_error</div>
        }

        <div class="form-actions">
            <button type="submit" class="btn primary" disabled="@_saving">@(_saving ? "Saving…" : "Save")</button>
        </div>
    </EditForm>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true,
        Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
    };

    private enum ViewMode { Simple, Advanced }

    private HomeYarp.Domain.Application _model = NewModel();
    private IReadOnlyList<HomeYarp.Domain.Certificate> _certificates = Array.Empty<HomeYarp.Domain.Certificate>();
    private bool _isNew = true;
    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private bool _acmeReady;
    private string? _error;
    private ViewMode _view = ViewMode.Simple;
    private string _jsonBuffer = "{}";
    private string? _jsonError;

    protected override async Task OnParametersSetAsync()
    {
        _isNew = !Id.HasValue;
        _loading = true;
        _notFound = false;
        _error = null;

        _certificates = await CertificateService.ListAsync();
        _acmeReady = AcmeOptionsValidator.IsConfigured(AcmeOptions.CurrentValue);

        if (_isNew)
        {
            _model = NewModel();
        }
        else
        {
            var existing = await Service.GetAsync(Id!.Value);
            if (existing is null)
            {
                _notFound = true;
            }
            else
            {
                _model = existing;
            }
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            if (_isNew)
            {
                await Service.CreateAsync(_model);
            }
            else
            {
                await Service.UpdateAsync(Id!.Value, _model);
            }
            Nav.NavigateTo("applications");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void SwitchToAdvanced()
    {
        if (_view == ViewMode.Advanced) return;
        _jsonBuffer = JsonSerializer.Serialize(_model, JsonOptions);
        _jsonError = null;
        _error = null;
        _view = ViewMode.Advanced;
    }

    private void SwitchToSimple()
    {
        if (_view == ViewMode.Simple) return;
        if (!TryParseJsonBuffer(out var parsed, out var error))
        {
            _jsonError = $"Fix the JSON before switching to Simple: {error}";
            return;
        }
        _model = parsed!;
        _jsonError = null;
        _error = null;
        _view = ViewMode.Simple;
    }

    private async Task SaveAdvancedAsync()
    {
        _saving = true;
        _error = null;
        _jsonError = null;

        if (!TryParseJsonBuffer(out var parsed, out var parseError))
        {
            _jsonError = parseError;
            _saving = false;
            return;
        }

        try
        {
            // Preserve identity for an update — the form's URL says which app this is.
            if (_isNew)
            {
                var created = await Service.CreateAsync(parsed!);
                _model = created;
                Nav.NavigateTo("applications");
            }
            else
            {
                var updated = await Service.UpdateAsync(Id!.Value, parsed!);
                _model = updated;
                Nav.NavigateTo("applications");
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private bool TryParseJsonBuffer(out HomeYarp.Domain.Application? parsed, out string? error)
    {
        parsed = null;
        error = null;
        if (string.IsNullOrWhiteSpace(_jsonBuffer))
        {
            error = "JSON is empty.";
            return false;
        }
        try
        {
            parsed = JsonSerializer.Deserialize<HomeYarp.Domain.Application>(_jsonBuffer, JsonOptions);
            if (parsed is null)
            {
                error = "JSON deserialized to null.";
                return false;
            }
            return true;
        }
        catch (JsonException ex)
        {
            error = ex.Message;
            return false;
        }
    }

    private void SetSource(TlsCertificateSource source)
    {
        _model.Tls.Source = source;
        if (source != TlsCertificateSource.Manual)
        {
            // Auto-managed sources own CertificateId — clear the user's stale pick so the service can populate on save.
            _model.Tls.CertificateId = null;
        }
    }

    private void AddRoute() => _model.Routes.Add(new RouteDefinition { Hosts = new List<string>() });

    private void AddDestination() => _model.Cluster.Destinations.Add(new DestinationDefinition
    {
        Name = $"dest-{_model.Cluster.Destinations.Count + 1}",
        Address = "https://"
    });

    private void UpdateHosts(int index, string? raw)
    {
        var hosts = string.IsNullOrWhiteSpace(raw)
            ? new List<string>()
            : raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        _model.Routes[index].Hosts = hosts;
    }

    private static HomeYarp.Domain.Application NewModel() => new()
    {
        Name = string.Empty,
        Routes = new List<RouteDefinition> { new() { Hosts = new List<string>() } },
        Cluster = new ClusterDefinition
        {
            Destinations = new List<DestinationDefinition>
            {
                new() { Name = "primary", Address = "https://" }
            }
        }
    };
}
