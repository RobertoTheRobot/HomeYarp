@page "/certificates/upload"
@using HomeYarp.Application.Abstractions
@inject ICertificateService Service
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Upload certificate · HomeYarp</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Upload certificate</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="certificates">Back</MudButton>
</MudStack>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Identity</MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Name (slug)"
                              Required="true"
                              RequiredError="Name is required"
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_friendlyName"
                              Label="Friendly name"
                              Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">PEM material</MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_certPem"
                              Label="Certificate (PEM)"
                              Lines="10"
                              Required="true"
                              RequiredError="Certificate PEM is required"
                              Placeholder="-----BEGIN CERTIFICATE-----…"
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_keyPem"
                              Label="Private key (PEM)"
                              Lines="10"
                              Required="true"
                              RequiredError="Private key PEM is required"
                              Placeholder="-----BEGIN PRIVATE KEY-----…"
                              Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>
    </MudItem>

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                @_error
            </MudAlert>
        </MudItem>
    }

    <MudItem xs="12">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upload"
                   Disabled="_uploading"
                   OnClick="UploadAsync">
            @(_uploading ? "Uploading…" : "Upload")
        </MudButton>
    </MudItem>
</MudGrid>

@code {
    private string _name = string.Empty;
    private string _friendlyName = string.Empty;
    private string _certPem = string.Empty;
    private string _keyPem = string.Empty;
    private bool _uploading;
    private string? _error;

    private async Task UploadAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_certPem) || string.IsNullOrWhiteSpace(_keyPem))
        {
            _error = "Name, certificate PEM, and private key PEM are required.";
            return;
        }
        _uploading = true;
        try
        {
            var material = new CertificateMaterial(_certPem, _keyPem);
            await Service.UploadAsync(_name, string.IsNullOrWhiteSpace(_friendlyName) ? null : _friendlyName, material);
            Nav.NavigateTo("certificates");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _uploading = false;
        }
    }
}
