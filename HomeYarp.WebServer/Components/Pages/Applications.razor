@page "/applications"
@inject IApplicationService Service
@inject ICertificateService CertificateService
@inject IDialogService DialogService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Applications · HomeYarp</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Applications</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="applications/new">
        New application
    </MudButton>
</MudStack>

@if (_apps is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="HomeYarp.Domain.Application"
                 Items="@_apps"
                 QuickFilter="@_quickFilter"
                 Filterable="false"
                 Hideable="false"
                 Hover="true"
                 Dense="true"
                 Bordered="false"
                 Elevation="1">
        <ToolBarContent>
            <MudTextField @bind-Value="_search"
                          Placeholder="Search name, host, or destination"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Immediate="true"
                          Clearable="true"
                          Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <CellTemplate>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2"><b>@context.Item.Name</b></MudText>
                        @if (!string.IsNullOrWhiteSpace(context.Item.DisplayName))
                        {
                            <MudText Typo="Typo.caption">@context.Item.DisplayName</MudText>
                        }
                    </MudStack>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Hosts" SortBy="@(new Func<HomeYarp.Domain.Application, object>(x => HostsOf(x)))">
                <CellTemplate>@HostsOf(context.Item)</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Destinations" Sortable="false">
                <CellTemplate>
                    <MudStack Spacing="1">
                        @foreach (var d in context.Item.Cluster.Destinations)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@d.Address</MudChip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Enabled" Title="Enabled">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Enabled ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                             Color="@(context.Item.Enabled ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="" Sortable="false" CellStyle="text-align:right;">
                <CellTemplate>
                    @{
                        var linkedCert = LinkedCert(context.Item);
                    }
                    @if (linkedCert is not null)
                    {
                        <MudTooltip Text="Download certificate (.pem)">
                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                           Size="Size.Small"
                                           Href="@($"api/certificates/{linkedCert.Id}/download")" />
                        </MudTooltip>
                        @if (linkedCert.SelfSigned is not null)
                        {
                            <MudTooltip Text="How to trust this cert">
                                <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                               Size="Size.Small"
                                               OnClick="() => ShowTrustInstructionsAsync(linkedCert)" />
                            </MudTooltip>
                        }
                    }
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Href="@($"applications/{context.Item.Id}")" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => DeleteAsync(context.Item)" />
                    </MudTooltip>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText Class="pa-4" Align="Align.Center">
                No applications yet. Create one to start proxying traffic.
            </MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="HomeYarp.Domain.Application" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private IReadOnlyList<HomeYarp.Domain.Application>? _apps;
    private Dictionary<Guid, HomeYarp.Domain.Certificate> _certsById = new();
    private string _search = string.Empty;

    private Func<HomeYarp.Domain.Application, bool> _quickFilter => app =>
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var q = _search.Trim();
        if (app.Name.Contains(q, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrWhiteSpace(app.DisplayName) &&
            app.DisplayName.Contains(q, StringComparison.OrdinalIgnoreCase)) return true;
        if (app.Routes.SelectMany(r => r.Hosts).Any(h => h.Contains(q, StringComparison.OrdinalIgnoreCase))) return true;
        if (app.Cluster.Destinations.Any(d => d.Address.Contains(q, StringComparison.OrdinalIgnoreCase))) return true;
        return false;
    };

    private static string HostsOf(HomeYarp.Domain.Application app) =>
        string.Join(", ", app.Routes.SelectMany(r => r.Hosts).Distinct());

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _apps = await Service.ListAsync();
        var certs = await CertificateService.ListAsync();
        _certsById = certs.ToDictionary(c => c.Id);
    }

    private HomeYarp.Domain.Certificate? LinkedCert(HomeYarp.Domain.Application app)
    {
        if (app.Tls.CertificateId is not { } id) return null;
        return _certsById.TryGetValue(id, out var cert) ? cert : null;
    }

    private async Task DeleteAsync(HomeYarp.Domain.Application app)
    {
        await Service.DeleteAsync(app.Id);
        await Reload();
    }

    private async Task ShowTrustInstructionsAsync(HomeYarp.Domain.Certificate cert)
    {
        var primaryHost = cert.SubjectAlternativeNames.FirstOrDefault()
            ?? cert.SelfSigned?.Hostnames.FirstOrDefault()
            ?? cert.Subject;
        var parameters = new DialogParameters
        {
            ["CertSlug"] = cert.Name,
            ["PrimaryHost"] = primaryHost
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<TrustCertificateDialog>("Trust this certificate", parameters, options);
    }
}
