@page "/certificates/generate"
@using HomeYarp.Application.SelfSigned
@using HomeYarp.Domain
@inject ISelfSignedCertificateService SelfSigned
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Generate self-signed · HomeYarp</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Generate self-signed certificate</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="certificates">Back</MudButton>
</MudStack>

<MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Info">
    HomeYarp will generate a private key and self-sign a certificate for the hostnames below.
    Use this for internal-only services that aren't reachable from the public internet — clients
    will need to trust HomeYarp's cert (or be told to ignore the warning) since it isn't issued
    by a public CA.
</MudAlert>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Identity</MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Name (slug)"
                              Required="true"
                              RequiredError="Name is required"
                              Placeholder="e.g. homeassistant-internal"
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_friendlyName"
                              Label="Friendly name"
                              Placeholder="e.g. Home Assistant (internal)"
                              Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Key &amp; validity</MudText>
            <MudStack Spacing="3">
                <MudSelect T="CertificateKeyType" @bind-Value="_keyType" Label="Key type" Variant="Variant.Outlined">
                    <MudSelectItem Value="@CertificateKeyType.Ec256">EC P-256 (recommended)</MudSelectItem>
                    <MudSelectItem Value="@CertificateKeyType.Rsa2048">RSA 2048</MudSelectItem>
                </MudSelect>
                <MudNumericField T="int" @bind-Value="_validityDays"
                                 Label="Validity (days)"
                                 Min="1" Max="3650"
                                 Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-2">Hostnames</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                One per line. The first becomes the certificate's Common Name. IP addresses go into
                the SAN as IP entries; everything else as DNS entries. Wildcards (<code>*.home.lan</code>)
                are allowed for self-signed certs.
            </MudText>
            <MudTextField @bind-Value="_hostnames"
                          Lines="6"
                          Required="true"
                          RequiredError="At least one hostname is required"
                          Placeholder="homeassistant.home.lan&#10;192.168.1.50"
                          Variant="Variant.Outlined" />
        </MudPaper>
    </MudItem>

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                @_error
            </MudAlert>
        </MudItem>
    }

    @if (_steps.Count > 0)
    {
        <MudItem xs="12">
            <ProgressLog Steps="_steps" />
        </MudItem>
    }

    <MudItem xs="12">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                   Disabled="_busy"
                   OnClick="GenerateAsync">
            @(_busy ? "Generating…" : "Generate certificate")
        </MudButton>
    </MudItem>
</MudGrid>

@code {
    private string _name = string.Empty;
    private string _friendlyName = string.Empty;
    private string _hostnames = string.Empty;
    private CertificateKeyType _keyType = CertificateKeyType.Ec256;
    private int _validityDays = 365;
    private bool _busy;
    private string? _error;
    private readonly List<ProgressStep> _steps = new();
    private IProgress<string>? _progress;

    protected override void OnInitialized()
    {
        _progress = new Progress<string>(message =>
        {
            _steps.Add(new ProgressStep(DateTimeOffset.Now, message));
            StateHasChanged();
        });
    }

    private async Task GenerateAsync()
    {
        _error = null;
        _steps.Clear();
        var hosts = (_hostnames ?? string.Empty)
            .Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Name is required.";
            return;
        }
        if (hosts.Count == 0)
        {
            _error = "At least one hostname is required.";
            return;
        }

        _busy = true;
        try
        {
            await SelfSigned.IssueAsync(
                _name,
                string.IsNullOrWhiteSpace(_friendlyName) ? null : _friendlyName,
                hosts,
                _keyType,
                _validityDays,
                progress: _progress);
            Nav.NavigateTo("certificates");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
