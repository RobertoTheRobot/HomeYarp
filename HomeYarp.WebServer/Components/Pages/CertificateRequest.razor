@page "/certificates/request"
@using HomeYarp.Application.Acme
@inject IAcmeService Acme
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Request certificate · HomeYarp</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Request certificate from Let's Encrypt</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="certificates">Back</MudButton>
</MudStack>

<MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Info">
    HomeYarp will request a fresh certificate from Let's Encrypt over the ACME HTTP-01 challenge.
    Each hostname must publicly resolve to this server, and inbound port 80 must reach the HTTP listener.
    Configure ACME first under <MudLink Href="settings">Settings</MudLink> &mdash;
    <code>HomeYarp:Acme:Enabled</code>, <code>AccountEmail</code>, and
    <code>AgreeToTermsOfService</code> must all be set.
</MudAlert>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Identity</MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Name (slug)"
                              Required="true"
                              RequiredError="Name is required"
                              Placeholder="e.g. cloud-example"
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_friendlyName"
                              Label="Friendly name"
                              Placeholder="e.g. Cloud (Let's Encrypt)"
                              Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-2">Hostnames</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                One per line. The first hostname becomes the certificate's Common Name.
                Wildcards (<code>*.example.com</code>) are not supported &mdash; HTTP-01 cannot validate them.
            </MudText>
            <MudTextField @bind-Value="_hostnames"
                          Lines="6"
                          Required="true"
                          RequiredError="At least one hostname is required"
                          Placeholder="cloud.example.com&#10;www.cloud.example.com"
                          Variant="Variant.Outlined" />
        </MudPaper>
    </MudItem>

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                @_error
            </MudAlert>
        </MudItem>
    }

    @if (_steps.Count > 0)
    {
        <MudItem xs="12">
            <ProgressLog Steps="_steps" />
        </MudItem>
    }

    <MudItem xs="12">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CloudDownload"
                   Disabled="_busy"
                   OnClick="RequestAsync">
            @(_busy ? "Requesting…" : "Request certificate")
        </MudButton>
    </MudItem>
</MudGrid>

@code {
    private string _name = string.Empty;
    private string _friendlyName = string.Empty;
    private string _hostnames = string.Empty;
    private bool _busy;
    private string? _error;
    private readonly List<ProgressStep> _steps = new();
    private IProgress<string>? _progress;

    protected override void OnInitialized()
    {
        _progress = new Progress<string>(message =>
        {
            _steps.Add(new ProgressStep(DateTimeOffset.Now, message));
            StateHasChanged();
        });
    }

    private async Task RequestAsync()
    {
        _error = null;
        _steps.Clear();
        var hosts = (_hostnames ?? string.Empty)
            .Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Name is required.";
            return;
        }
        if (hosts.Count == 0)
        {
            _error = "At least one hostname is required.";
            return;
        }

        _busy = true;
        try
        {
            await Acme.IssueAsync(
                _name,
                string.IsNullOrWhiteSpace(_friendlyName) ? null : _friendlyName,
                hosts,
                progress: _progress);
            Nav.NavigateTo("certificates");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
