@* Triggers IRuntimeReloadService and renders a live progress log + last-reload timestamp.
   Saves no longer auto-reload — the user clicks this when they're ready to apply changes. *@

@inject IRuntimeReloadService ReloadService
@inject NavigationManager Nav
@implements IDisposable

<MudStack Spacing="2">
    <MudButton Variant="@(Compact ? Variant.Outlined : Variant.Filled)"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh"
               Disabled="_busy"
               OnClick="ReloadAsync"
               FullWidth="@Compact">
        @(_busy ? "Reloading…" : "Reload runtime")
    </MudButton>

    @if (!Compact)
    {
        <MudText Typo="Typo.caption">
            @if (ReloadService.LastReloadedAt is { } when)
            {
                @($"Last reload: {when.ToLocalTime():HH:mm:ss}")
            }
            else
            {
                @("Not reloaded yet (running on startup snapshot)")
            }
        </MudText>
    }

    @if (_steps.Count > 0)
    {
        <ProgressLog Steps="_steps" />
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _error = null">
            @_error
        </MudAlert>
    }
</MudStack>

@code {
    /// <summary>When true, render only the button (no metadata row). Use in tight spots like the sidebar.</summary>
    [Parameter] public bool Compact { get; set; }

    /// <summary>Optional callback fired after a successful reload (e.g. to refresh a page-local list).</summary>
    [Parameter] public EventCallback OnReloaded { get; set; }

    private bool _busy;
    private string? _error;
    private readonly List<ProgressStep> _steps = new();
    private IProgress<string>? _progress;

    protected override void OnInitialized()
    {
        _progress = new Progress<string>(message =>
        {
            _steps.Add(new ProgressStep(DateTimeOffset.Now, message));
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        _error = null;
        _steps.Clear();
        try
        {
            await ReloadService.ReloadAsync(_progress);
            if (OnReloaded.HasDelegate)
            {
                await OnReloaded.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose()
    {
        // Nothing to dispose — IProgress<T> doesn't hold unmanaged resources.
        // Implementing IDisposable so Blazor unwires the component cleanly.
    }
}
